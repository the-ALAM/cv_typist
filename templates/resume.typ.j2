// ---- ACTE Generated ATS-Friendly Resume ----
// All dimension variables are injected by Python. Do not hardcode values.

#import "@preview/ats-friendly-resume:0.1.1": *

#show: resume.with(
  author: "{{ personal.name | te if personal else '' }}",
  author-position: center,
{% if personal and personal.get("location") %}
  location: "{{ personal.location | te }}",
{% endif %}
{% if personal and personal.get("email") %}
  email: "{{ personal.email | te }}",
{% endif %}
{% if personal and personal.get("phone") %}
  phone: "{{ personal.phone | te }}",
{% endif %}
{% if personal and personal.get("linkedin") %}
  linkedin: "{{ personal.linkedin | te }}",
{% endif %}
{% if personal and personal.get("github") %}
  github: "{{ personal.github | te }}",
{% endif %}
{% if personal and personal.get("portfolio") %}
  portfolio: "{{ personal.portfolio | te }}",
{% endif %}
  personal-info-position: center,
  color-enabled: false,
  font: "New Computer Modern",
  paper: "a4",
  author-font-size: {{ (layout.font_size_pt * 2) | round(1) }}pt,
  font-size: {{ layout.font_size_pt }}pt,
  lang: "en",
)

{% if skills is defined and skills %}
== Technical Skills
{% for category, items in skills.items() %}
- *{{ category | te }}*: {{ items | join(", ") }}
{% endfor %}

{% endif %}
{% if experiences %}
== Experience

{% for exp in experiences %}
#work(
  company: "{{ exp.company | te }}",
  role: "{{ exp.role | te }}",
  dates: "{{ exp.date | te }}",
)
{% for bullet in exp.bullets %}
- {{ bullet | te }}
{% endfor %}

{% endfor %}
{% endif %}
{% if projects is defined and projects %}
== Projects

{% for proj in projects %}
#project(
  name: "{{ proj.name | te }}",
  dates: "{{ proj.date | te }}",
{% if proj.get("tech_used") %}
  tech-used: "{{ proj.tech_used | te }}",
{% endif %}
{% if proj.get("url") %}
  url: "{{ proj.url | te }}",
{% endif %}
)
{% for bullet in proj.bullets %}
- {{ bullet | te }}
{% endfor %}

{% endfor %}
{% endif %}
{% if education is defined and education %}
== Education

{% for edu in education %}
#edu(
  institution: "{{ edu.institution | te }}",
  location: "{{ edu.location | te }}",
  degree: "{{ edu.degree | te }}",
  dates: "{{ edu.date | te }}",
)
{% endfor %}
{% endif %}
